# Server Configuration
PORT=5000

# JWT Auth Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Supabase Credentials (Leave blank or default to use in-memory Mock Mode)
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Razorpay Credentials (Leave blank or default to use simulated payment checkout)
RAZORPAY_KEY_ID=rzp_test_yourKeyHere
RAZORPAY_KEY_SECRET=yourRazorpaySecretHere

# ── Communication Module (Phase 11) ──
# Provider selection: "mock" (default) or "msg91"
COMMUNICATION_PROVIDER=mock

# Mock provider behavior (optional, dev only)
MOCK_COMM_SIMULATE_FAILURES=false
MOCK_COMM_FAILURE_RATE=0.1
MOCK_COMM_SIMULATE_DELAY=false
MOCK_COMM_DELAY_MS=100

# MSG91 Credentials (only required when COMMUNICATION_PROVIDER=msg91)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=
MSG91_OTP_TEMPLATE=
MSG91_WHATSAPP_TEMPLATE=

# OTP Configuration
COMM_OTP_LENGTH=6
COMM_OTP_EXPIRY_MINUTES=5
COMM_OTP_MAX_ATTEMPTS=5

# Communication Queue Configuration
COMM_QUEUE_RETRY_MAX=3
COMM_QUEUE_RETRY_BASE_DELAY=1000
COMM_QUEUE_POLL_INTERVAL=500

# Communication Log Level
COMM_LOG_LEVEL=info
COMM_LOG_DIR=logs/communication
